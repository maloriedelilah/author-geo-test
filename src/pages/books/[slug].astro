---
// Book detail page. Builds the @graph (Book, cross-linked by @id) via the engine's
// jsonld.ts builder, sourced ONLY through the ContentSource seam (FileSource).
//
// DD-001 note: this page does NOT emit the full Person node anymore — that lives
// exactly once on /about. It references each of the book's authors by @id + named
// stub (bookNode's `authors` opt), co-author-safe via Book.authorSlugs.
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import { FileSource } from '../../lib/sources/FileSource';
import { bookNode, graph } from '../../lib/jsonld';

const source = new FileSource();

export async function getStaticPaths() {
  const src = new FileSource();
  const books = await src.getBooks();
  return books.map((book) => ({ params: { slug: book.slug } }));
}

const { slug } = Astro.params;
const book = await source.getBook(slug as string);
if (!book) throw new Error(`No book found for slug "${slug}"`);

const allAuthors = await source.getAuthors();
const bookAuthors = allAuthors
  .filter((a) => book.authorSlugs.includes(a.slug))
  .map((a) => ({ slug: a.slug, name: a.name }));
if (bookAuthors.length === 0) {
  throw new Error(`Book "${book.slug}" has no resolvable author (authorSlugs: ${book.authorSlugs.join(', ')})`);
}

// Resolve the series to a {slug, name} so bookNode can emit isPartOf as a NAMED
// STUB (DD-001) rather than a bare @id that would dangle on this page.
const series = book.seriesSlug
  ? await source.getSeriesBySlug(book.seriesSlug)
  : undefined;

const pageGraph = graph([
  bookNode(book, {
    series: series ? { slug: series.slug, name: series.name } : undefined,
    authors: bookAuthors,
  }),
]);

const byline = bookAuthors.map((a) => a.name).join(', ');
---
<Base title={`${book.title} — ${byline}`} description={book.description}>
  <JsonLd graph={pageGraph} />
  <article>
    <h1>{book.title}</h1>
    {book.subtitle && <p class="subtitle">{book.subtitle}</p>}
    <img src={book.cover} alt={`Cover of ${book.title}`} />
    <p>{book.description}</p>
    <p>By <a href="/about">{byline}</a></p>

    <section aria-label="Editions">
      <h2>Get the book</h2>
      <ul>
        {book.editions.map((e) => (
          <li>
            <a href={e.url}>{e.retailer} ({e.format})</a>
            {e.price && <span> — {e.price} {e.currency}</span>}
          </li>
        ))}
      </ul>
    </section>

    {book.comps.length > 0 && (
      <section aria-label="If you like...">
        <h2>If you like...</h2>
        <ul>
          {book.comps.map((c) => (
            <li><strong>{c.name}</strong>: {c.hook}</li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>
