---
// Theme (hub) detail page. Mirrors books/[slug].astro and series/[slug].astro.
// Route is /themes/<slug> (matches the live aeon14.com convention per the
// manifest note); the underlying content collection is `hubs`.
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import CompsBlock from '../../components/CompsBlock.astro';
import { FileSource } from '../../lib/sources/FileSource';
import { hubGraph, bookId, graph } from '../../lib/jsonld';

const source = new FileSource();

export async function getStaticPaths() {
  const src = new FileSource();
  const hubs = await src.getHubs();
  return hubs.map((h) => ({ params: { slug: h.slug } }));
}

const { slug } = Astro.params;
const hub = await source.getHub(slug as string);
if (!hub) throw new Error(`No theme found for slug "${slug}"`);

const allBooks = await source.getBooks();
const memberBooks = hub.bookSlugs
  .map((s) => allBooks.find((b) => b.slug === s))
  .filter((b): b is NonNullable<typeof b> => Boolean(b));
// Pass {id, name} so hubGraph emits a NAMED STUB per member (DD-001) — a bare
// @id here would dangle on a standalone fetch of just this page's JSON-LD.
const members = memberBooks.map((b) => ({ id: bookId(b.slug), name: b.title }));

const pageGraph = graph([hubGraph(hub, members)]);
---
<Base title={hub.name} description={hub.description}>
  <JsonLd graph={pageGraph} />
  <article>
    <h1>{hub.name}</h1>
    <p>{hub.description}</p>

    <section aria-label="Books in this theme">
      <h2>Books</h2>
      <ol>
        {memberBooks.map((b) => (
          <li><a href={`/books/${b.slug}`}>{b.title}</a></li>
        ))}
      </ol>
    </section>

    <CompsBlock comps={hub.comps} />
  </article>
</Base>
