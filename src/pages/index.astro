---
// Home / author landing.
//
// DD-001: this page emits NO page-level JSON-LD of its own. Base.astro already
// emits the sitewide WebSite (with publisher as a named stub — DD-001), and the
// author blurb below is DISPLAY TEXT ONLY, linking to /about#<slug> where the
// canonical full Person node lives exactly once. Emitting a second full Person
// node (or even a bare @id) here would violate the identity spine, so: don't.
import Base from '../layouts/Base.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import ComingSoonRow from '../components/ComingSoonRow.astro';
import { FileSource } from '../lib/sources/FileSource';
import { siteConfig } from '../config';
import { isFutureRelease, formatDate } from '../lib/date';

const source = new FileSource();
const [books, seriesList, authors] = await Promise.all([
  source.getBooks(),
  source.getSeries(),
  source.getAuthors(),
]);

const now = new Date();

// "Preorder" is never a separate field — a book with a future datePublished
// IS a preorder, everywhere on the site at once (see lib/date.ts's
// isFutureRelease doc comment: this same check also drives jsonld.ts's
// Offer.availability and the PRE-ORDER badge on series listings/book pages).
const releasedBooks = books.filter((b) => !isFutureRelease(b.datePublished, now));
const upcomingBooks = books
  .filter((b) => isFutureRelease(b.datePublished, now))
  .sort((a, b) => a.datePublished.getTime() - b.datePublished.getTime()); // soonest first

// (a) Hero slideshow: most recently RELEASED book first, then every upcoming
// book as its own slide (soonest first) — see HeroSlideshow.astro. A book
// never appears here before it's either released or genuinely upcoming, so
// this can never show something that isn't real yet.
const latestRelease = [...releasedBooks].sort(
  (a, b) => b.datePublished.getTime() - a.datePublished.getTime(),
)[0];

const heroSlides = [
  ...(latestRelease ? [{ kind: 'latest' as const, book: latestRelease }] : []),
  ...upcomingBooks.map((book) => ({ kind: 'comingSoon' as const, book })),
].map(({ kind, book }) => ({
  kind,
  slug: book.slug,
  title: book.title,
  cover: book.cover,
  description: book.description,
  releaseDate: formatDate(book.datePublished),
}));

// (b) Coming soon row: same upcoming-book set, with series context resolved
// for the "Book N of <Series>" line.
const seriesBySlug = new Map(seriesList.map((s) => [s.slug, s] as const));
const comingSoonBooks = upcomingBooks.map((b) => {
  const s = b.seriesSlug ? seriesBySlug.get(b.seriesSlug) : undefined;
  return {
    slug: b.slug,
    title: b.title,
    cover: b.cover,
    releaseDate: formatDate(b.datePublished),
    seriesName: s?.name,
    seriesSlug: s?.slug,
    seriesPosition: b.seriesPosition,
  };
});

// (c) Each series, with its member books (ordered by seriesPosition) —
// intentionally ALL member books including any upcoming ones, so a reader
// browsing a series here sees its full lineup; an upcoming entry still gets
// the same PRE-ORDER badge treatment as everywhere else.
const seriesWithBooks = seriesList.map((s) => ({
  series: s,
  books: books
    .filter((b) => b.seriesSlug === s.slug)
    .sort((a, b) => (a.seriesPosition ?? 0) - (b.seriesPosition ?? 0)),
}));

// (d) Truncated "about the author" blurb for the site's main author — the same
// primary/first author entry Base.astro treats as the WebSite publisher.
const primaryAuthor = authors[0];
const BIO_TRUNCATE_CHARS = 220;
const truncatedBio = primaryAuthor && primaryAuthor.bio.length > BIO_TRUNCATE_CHARS
  ? `${primaryAuthor.bio.slice(0, BIO_TRUNCATE_CHARS).trimEnd()}…`
  : primaryAuthor?.bio;
---
<Base
  title={primaryAuthor?.name ?? 'Home'}
  description={primaryAuthor?.bio}
  image={latestRelease?.cover}
>
  <h1 class="visually-hidden">{primaryAuthor?.name ?? 'Home'}</h1>

  {siteConfig.slogan && (
    <p class="site-slogan">{siteConfig.slogan}</p>
  )}

  <HeroSlideshow slides={heroSlides} intervalSeconds={siteConfig.heroSlideshow.intervalSeconds} />

  <ComingSoonRow books={comingSoonBooks} />

  {seriesWithBooks.length > 0 && (
    <section aria-label="Series">
      <h2>Series</h2>
      {seriesWithBooks.map(({ series, books: memberBooks }) => (
        <article class="card series-card">
          <h3><a href={`/series/${series.slug}`}>{series.name}</a></h3>
          <p class="series-description">{series.description}</p>
          <div class="series-list-row">
            <ul>
              {memberBooks.map((b) => (
                <li>
                  <a href={`/books/${b.slug}`}>{b.title}</a>
                  {isFutureRelease(b.datePublished, now) && <span class="preorder-badge">Pre-order</span>}
                </li>
              ))}
            </ul>
            {memberBooks.length > 0 && (
              <div class="series-covers-stack" aria-hidden="true">
                {memberBooks.slice(0, 3).map((b, i) => (
                  <img
                    class="stacked-cover"
                    style={`z-index: ${3 - i};`}
                    src={b.cover}
                    alt=""
                  />
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </section>
  )}

  {primaryAuthor && (
    <section aria-label="About the author">
      <h2>About {primaryAuthor.name}</h2>
      <div class="author-card">
        {primaryAuthor.photo && (
          <img class="author-photo" src={primaryAuthor.photo} alt={primaryAuthor.name} />
        )}
        <div class="author-card-body">
          <p>{truncatedBio}</p>
          <p><a href={`/about#${primaryAuthor.slug}`}>More about {primaryAuthor.name} &rarr;</a></p>
        </div>
      </div>
    </section>
  )}
</Base>
