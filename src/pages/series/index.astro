---
// Series index — landing page for the "Series" nav item. Lists every series
// with its member books, same derivation logic as the homepage's series
// section. Emits only a BreadcrumbList of its own (Home -> Series); each
// series' full BookSeries node lives once on its own /series/<slug> page
// (DD-001) — this is a plain listing/navigation page otherwise.
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import BookListItem from '../../components/BookListItem.astro';
import { FileSource } from '../../lib/sources/FileSource';
import { breadcrumbNode, pageUrl, graph } from '../../lib/jsonld';

const source = new FileSource();
const [seriesList, books] = await Promise.all([
  source.getSeries(),
  source.getBooks(),
]);

const seriesWithBooks = seriesList.map((s) => ({
  series: s,
  books: books
    .filter((b) => b.seriesSlug === s.slug)
    .sort((a, b) => (a.seriesPosition ?? 0) - (b.seriesPosition ?? 0)),
}));

// This is a listing page, not any one series' own page — a representative
// cover (first series' cover, else its first book's) reads better on a
// shared link than falling all the way back to the author's own photo.
// shareImageAlt tracks shareImage's own fallback exactly (never the page
// title — see Base.astro's `imageAlt` doc) so they can't describe different
// images.
const firstSeries = seriesWithBooks[0];
const shareImage = firstSeries?.series.cover ?? firstSeries?.books[0]?.cover;
const shareImageAlt = firstSeries?.series.cover
  ? `Cover art for ${firstSeries.series.name}`
  : (firstSeries?.books[0] ? `Cover of ${firstSeries.books[0].title}` : undefined);

const pageGraph = graph([
  breadcrumbNode([{ name: 'Home', url: pageUrl('/') }, { name: 'Series' }]),
]);
---
<Base title="Series" description="All series" image={shareImage} imageAlt={shareImageAlt}>
  <Fragment slot="breadcrumbs">
    <a href="/">Home</a>
    <span class="sep" aria-hidden="true">/</span>
    <span aria-current="page">Series</span>
  </Fragment>
  <JsonLd graph={pageGraph} />
  <h1>Series</h1>
  {seriesWithBooks.length === 0 && <p>No series yet.</p>}
  {seriesWithBooks.map(({ series, books: memberBooks }) => (
    <section class="card" aria-labelledby={`series-${series.slug}`}>
      <h2 id={`series-${series.slug}`}><a href={`/series/${series.slug}`}>{series.name}</a></h2>
      <p class="series-description">{series.description}</p>
      <ul class="book-thumb-list">
        {memberBooks.map((b) => (
          <BookListItem
            slug={b.slug}
            title={b.title}
            cover={b.cover}
            description={b.description}
            seriesPosition={b.seriesPosition}
            datePublished={b.datePublished}
          />
        ))}
      </ul>
    </section>
  ))}
</Base>
