---
// Base layout: <head>, sitewide WebSite JSON-LD, breadcrumbs slot.
// Per-page @graph payloads (Book, Series, Hub, ...) are injected separately by the
// page templates themselves via <JsonLd graph={...} /> — this layout only carries
// the SITE-WIDE graph that belongs on every page.
//
// Identity spine (DD-001): WebSite.publisher must resolve on EVERY page, including
// ones that supply no author of their own (home, series, themes, events, About
// itself). So this layout reads the primary author from the ContentSource directly
// — it does NOT depend on the page passing one in — and emits a NAMED STUB
// (never a bare @id) pointing at the canonical Person node defined once on /about.
import JsonLd from '../components/JsonLd.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { authorId, namedStub } from '../lib/jsonld';
import { FileSource } from '../lib/sources/FileSource';
import { siteConfig } from '../config';
import '../styles/theme.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props as Props;

const source = new FileSource();
const authors = await source.getAuthors();
// Tier-1 product decision: single-author template each student clones (co-author
// arrays are supported end-to-end for when a book/series has one, but the SITE's
// publisher is the primary/first author entry).
const primaryAuthor = authors[0];
if (!primaryAuthor) {
  throw new Error('Base.astro: no author entry found in src/content/author — WebSite.publisher cannot be built');
}

const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': new URL('#website', Astro.site).toString(),
      url: siteConfig.siteUrl,
      name: title,
      publisher: namedStub(authorId(primaryAuthor.slug), primaryAuthor.name),
    },
  ],
};
---
<!doctype html>
<html lang="en" data-theme={siteConfig.theme.mode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={Astro.url.toString()} />
    <JsonLd graph={siteGraph} />
    {siteConfig.theme.accent && (
      <style set:html={`:root[data-theme="${siteConfig.theme.mode}"] { --accent: ${siteConfig.theme.accent}; }`} />
    )}
  </head>
  <body>
    <div class="site-shell">
      <Header authorName={primaryAuthor.name} />
      <nav aria-label="breadcrumbs">
        <slot name="breadcrumbs" />
      </nav>
      <main class="wrap">
        <slot />
      </main>
      <Footer authorName={primaryAuthor.name} sameAs={primaryAuthor.sameAs} />
    </div>
  </body>
</html>
