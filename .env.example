# Lead-capture secrets consumed by src/pages/api/subscribe.ts (not yet
# written — see README "Tier 2 — what's deferred") via the `cloudflare:workers`
# env import. Copy this file to `.env` for local dev (astro dev/build reads
# .env automatically) and set the same names as Cloudflare **Worker**
# environment variables/secrets for production (never commit real values).
#
# Which adapter is active is a CONFIG option, not an env var — see
# src/config.ts -> siteConfig.leads.provider ('mailerlite' | 'emailoctopus').
# You only need to fill in the block matching your chosen provider.

# --- MailerLite (siteConfig.leads.provider = 'mailerlite') ---
MAILERLITE_API_KEY=

# --- EmailOctopus (siteConfig.leads.provider = 'emailoctopus') ---
EMAILOCTOPUS_API_KEY=
EMAILOCTOPUS_LIST_ID=

# Contact-form secrets — LIVE, consumed by src/pages/api/contact.ts right now
# (see README "Contact form"). CONTACT_TO_EMAIL is your real inbox; it is
# NEVER read by the browser or committed anywhere, which is the whole point
# of routing the form through a server-side endpoint instead of a mailto:
# link or a visible email address in the page. CONTACT_FROM_EMAIL must be a
# sender verified on a domain set up in your Resend account.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Cloudflare Turnstile — LIVE spam gate on the contact form, layered on top
# of (not instead of) the honeypot field already in ContactForm.astro.
# TURNSTILE_SITE_KEY is public/embeddable, not actually a secret — it's read
# at BUILD time in ContactForm.astro's frontmatter (embedded as a
# `data-sitekey` attribute), not a Workers runtime secret, so it's also a
# required plain build variable in whatever CI/Cloudflare build step runs
# `npm run build` — missing it fails the build loudly (see README).
# TURNSTILE_SECRET_KEY is the real secret, verified server-side only.
#
# For local testing without a real Cloudflare Turnstile site: Cloudflare
# publishes "always passes" test keys —
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/ —
# site key 1x00000000000000000000AA / secret key
# 1x0000000000000000000000000000000AA are safe placeholders for a local
# build/dev loop; never use them in production.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
