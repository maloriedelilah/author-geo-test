# Lead-capture secrets consumed by src/pages/api/subscribe.ts via the
# `cloudflare:workers` env import. Copy this file to `.env` for local dev
# (astro dev reads .env automatically) and set the same names as Cloudflare
# Pages secrets for production (never commit real values).
#
# Which adapter is active is a CONFIG option, not an env var — see
# src/config.ts -> siteConfig.leads.provider ('mailerlite' | 'emailoctopus').
# You only need to fill in the block matching your chosen provider.

# --- MailerLite (siteConfig.leads.provider = 'mailerlite') ---
MAILERLITE_API_KEY=

# --- EmailOctopus (siteConfig.leads.provider = 'emailoctopus') ---
EMAILOCTOPUS_API_KEY=
EMAILOCTOPUS_LIST_ID=
